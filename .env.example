# Salesforce Environment Configuration
# Copy this file to .env, .env.sandbox, .env.dev, or .env.prod
# Set SF_ENV to choose which file to load (default: no suffix -> .env)

# Required: Your Salesforce org URL
SF_BASE_URL=https://your-org.lightning.force.com

# Login URL (standard Salesforce login or your SSO/custom domain)
SF_LOGIN_URL=https://login.salesforce.com

# --- Authentication ---
# LOCAL: Run `npm run auth` to log in interactively. No credentials needed here.
# CI:   Set SF_SESSION_ID as a GitHub secret (from Salesforce session or Connected App).
# SF_SESSION_ID=

# Documentation mode (set automatically by npm run test:document)
# CAPTURE_DOCS=true

# --- Persona Session IDs (for multi-role testing) ---
# Each persona can have its own session for parallel role-based tests.
# Only set the ones you need; tests will skip if the persona session is missing.
# SF_SESSION_INTERNAL_ADMIN=
# SF_SESSION_VENDOR_ADMIN=
# SF_SESSION_BUDGET_CREATOR=
# SF_SESSION_INVOICE_MANAGER=
# SF_SESSION_SITE_MANAGER=
# SF_SESSION_ENROLLMENT_MANAGER=
# SF_SESSION_ENROLLMENT_SPECIALIST=
# SF_SESSION_ATTENDANCE_TAKER=
# SF_SESSION_AFFILIATION_MANAGER=
# SF_SESSION_EDUCATION_SPECIALIST=
# SF_SESSION_FAMILY_WORKER=
# SF_SESSION_EDUCATION_DIRECTOR=
# SF_SESSION_MONITORING_SPECIALIST=
# SF_SESSION_STUDENT_SCREENER=
# SF_SESSION_CHECKLIST_MANAGER=
# SF_SESSION_CHECKLIST_VIEWER=
# SF_SESSION_CLASSROOM_CREATOR=
